<script>
// ── game carousel ─────────────────────────────────────────
(function () {
  const GAMES = JSON.parse(document.getElementById('gameData').textContent);
  let current = 0;

  const eyebrow  = document.getElementById('evEyebrow');
  const gameName = document.getElementById('evGameName');
  const headline = document.getElementById('evHeadline');
  const sub      = document.getElementById('evSub');
  const header   = document.getElementById('evHeader');
  const dots     = document.querySelectorAll('.ev-dot');
  const pages    = document.querySelectorAll('.ev-page');
  const prev     = document.getElementById('evPrev');
  const next     = document.getElementById('evNext');

  function goTo(idx) {
    if (idx === current) return;
    const g = GAMES[idx];

    // Fade header text
    header.classList.add('fading');
    setTimeout(() => {
      eyebrow.textContent  = g.eyebrow;
      gameName.textContent = g.name;
      headline.textContent = g.headline;
      sub.textContent      = g.sub;
      header.classList.remove('fading');
    }, 200);

    // Swap page
    pages[current].classList.remove('active');
    pages[idx].classList.remove('fade-in');
    void pages[idx].offsetWidth; // reflow to restart animation
    pages[idx].classList.add('active', 'fade-in');

    // Dots
    dots[current].classList.remove('active');
    dots[idx].classList.add('active');

    current = idx;
  }

  prev.addEventListener('click', () => goTo((current - 1 + GAMES.length) % GAMES.length));
  next.addEventListener('click', () => goTo((current + 1) % GAMES.length));
  dots.forEach(d => d.addEventListener('click', () => goTo(+d.dataset.index)));
}());

// ── helpers ──────────────────────────────────────────────
function rgb(hex) {
  const r = parseInt(hex.slice(1,3),16);
  const g = parseInt(hex.slice(3,5),16);
  const b = parseInt(hex.slice(5,7),16);
  return [r,g,b];
}
function rgba(hex, a) {
  const [r,g,b] = rgb(hex);
  return `rgba(${r},${g},${b},${a})`;
}

// ── effect: multizone start lights sweep ─────────────────
function startLightsEffect(canvas) {
  const N = 5;
  const strip = document.createElement('div');
  strip.style.cssText = 'position:absolute;bottom:0;left:0;right:0;height:5px;display:flex;gap:3px;padding:0 8px;box-sizing:border-box;';
  const segs = Array.from({length: N}, () => {
    const s = document.createElement('div');
    s.style.cssText = 'flex:1;border-radius:3px;background:rgba(239,68,68,0.12);transition:background .1s,box-shadow .1s;';
    strip.appendChild(s);
    return s;
  });
  canvas.appendChild(strip);

  let alive = true, timers = [];
  const t = (fn, ms) => { if (alive) timers.push(setTimeout(fn, ms)); };

  const run = () => {
    segs.forEach(s => { s.style.background='rgba(239,68,68,0.12)'; s.style.boxShadow=''; });
    segs.forEach((s,i) => t(() => {
      s.style.background = '#ef4444';
      s.style.boxShadow = '0 0 10px #ef4444, 0 0 22px rgba(239,68,68,0.55)';
    }, 180 + i * 420));
    // lights out
    t(() => segs.forEach(s => { s.style.background='rgba(239,68,68,0.08)'; s.style.boxShadow=''; }), 180 + N*420 + 500);
    t(run, 180 + N*420 + 2200);
  };
  run();
  return () => { alive=false; timers.forEach(clearTimeout); canvas.innerHTML=''; };
}

// ── effect: blink N times then pause ─────────────────────
// onMs: how long each flash is lit; offMs: gap between blinks; pauseMs: pause before repeating
function makeBlink(hex, count, onMs, offMs, pauseMs) {
  return (canvas) => {
    let alive = true, timers = [];
    const t = (fn, ms) => { if (alive) timers.push(setTimeout(fn, ms)); };
    const on  = () => { canvas.style.transition='none'; canvas.style.background=rgba(hex,0.45); canvas.style.boxShadow=`inset 0 0 60px ${rgba(hex,0.25)}`; };
    const off = () => { canvas.style.transition=`background ${offMs*0.6}ms ease,box-shadow ${offMs*0.6}ms ease`; canvas.style.background=''; canvas.style.boxShadow=''; };

    const run = () => {
      let delay = 0;
      for (let i = 0; i < count; i++) {
        t(on,  delay);          delay += onMs;
        t(off, delay);          delay += offMs;
      }
      t(run, delay + pauseMs);
    };
    run();
    return () => { alive=false; timers.forEach(clearTimeout); canvas.style.cssText=''; };
  };
}

// ── effect: smooth breathing pulse ───────────────────────
function makePulse(hex, periodMs) {
  return (canvas) => {
    let alive = true, raf;
    const start = performance.now();
    const [r,g,b] = rgb(hex);
    const tick = () => {
      const t = (performance.now() - start) / periodMs;
      const v = (Math.sin(t * Math.PI * 2) * 0.5 + 0.5);
      canvas.style.background = `rgba(${r},${g},${b},${(0.03 + v * 0.2).toFixed(3)})`;
      canvas.style.boxShadow = `inset 0 0 ${30 + v*40}px rgba(${r},${g},${b},${(v*0.12).toFixed(3)})`;
      if (alive) raf = requestAnimationFrame(tick);
    };
    raf = requestAnimationFrame(tick);
    return () => { alive=false; cancelAnimationFrame(raf); canvas.style.cssText=''; };
  };
}

// ── effect: urgent strobe (red flag) ─────────────────────
function redFlagEffect(canvas) {
  let alive = true, timers = [];
  const t = (fn, ms) => { if (alive) timers.push(setTimeout(fn, ms)); };
  const on  = () => { canvas.style.transition='none'; canvas.style.background='rgba(239,68,68,0.4)'; canvas.style.boxShadow='inset 0 0 60px rgba(239,68,68,0.25)'; };
  const off = () => { canvas.style.transition='background .15s, box-shadow .15s'; canvas.style.background=''; canvas.style.boxShadow=''; };

  const seq = [on,120,off,160,on,120,off,2000];
  const run = () => {
    let delay = 0;
    for (let i=0; i<seq.length; i++) {
      const item = seq[i];
      if (typeof item === 'function') t(item, delay);
      else delay += item;
    }
    t(run, delay);
  };
  run();
  return () => { alive=false; timers.forEach(clearTimeout); canvas.style.cssText=''; };
}

// ── effect: chequered flag ────────────────────────────────
function chequeredEffect(canvas) {
  canvas.style.cssText = 'position:absolute;inset:0;border-radius:inherit;overflow:hidden;pointer-events:none;z-index:0;';
  const checker = document.createElement('div');
  checker.style.cssText = `
    position:absolute;inset:0;
    background-image:repeating-conic-gradient(rgba(255,255,255,0.07) 0% 25%, transparent 0% 50%);
    background-size:18px 18px;
    opacity:0;transition:opacity .2s;
  `;
  const flash = document.createElement('div');
  flash.style.cssText = 'position:absolute;inset:0;background:transparent;transition:background .18s,box-shadow .18s;';
  canvas.appendChild(checker);
  canvas.appendChild(flash);

  let alive = true, timers = [];
  const t = (fn, ms) => { if (alive) timers.push(setTimeout(fn, ms)); };

  const run = () => {
    // green flash
    checker.style.opacity = '0';
    flash.style.transition = 'none';
    flash.style.background = 'rgba(34,197,94,0.45)';
    flash.style.boxShadow = 'inset 0 0 60px rgba(34,197,94,0.25)';
    t(() => {
      flash.style.transition = 'background .2s ease, box-shadow .2s ease';
      flash.style.background = 'transparent';
      flash.style.boxShadow = '';
      // white flash + checker
      t(() => {
        checker.style.opacity = '1';
        flash.style.transition = 'none';
        flash.style.background = 'rgba(255,255,255,0.35)';
        flash.style.boxShadow = 'inset 0 0 60px rgba(255,255,255,0.2)';
        t(() => {
          flash.style.transition = 'background .18s ease, box-shadow .18s ease';
          flash.style.background = 'transparent';
          flash.style.boxShadow = '';
          t(() => { checker.style.opacity='0.12'; t(run, 1400); }, 400);
        }, 280);
      }, 260);
    }, 220);
  };
  run();
  return () => { alive=false; timers.forEach(clearTimeout); canvas.innerHTML=''; canvas.style.cssText=''; };
}

// ── effect registry ───────────────────────────────────────
const handlers = {
  'start-lights':   startLightsEffect,
  'lights-out':     makeBlink('#22c55e', 2,  200, 200, 1800),
  'yellow-flag':    makeBlink('#f59e0b', 3,  300, 350, 1400),
  'blue-flag':      makePulse('#60a5fa', 1000),
  'red-flag':       makePulse('#ef4444', 1000),
  'fastest-lap':    makeBlink('#c084fc', 3,  120, 150, 1600),
  'chequered-flag': chequeredEffect,
  'white-warning':  makeBlink('#cbd5e1', 3,  200, 240, 1400),
  'neutral':        makePulse('#fbbf24', 2000),
  'crash':          makeBlink('#ffffff', 1,  120, 0,   1800),
};

// ── wire up cards (all game pages) ───────────────────────
const cleanups = new WeakMap();

document.querySelectorAll('.ev-page .event-card[data-effect]').forEach(card => {
  const canvas = card.querySelector('.effect-canvas');
  const id = card.dataset.effect;
  const handler = handlers[id];
  if (!handler || !canvas) return;

  card.addEventListener('mouseenter', () => {
    if (cleanups.has(card)) return;
    cleanups.set(card, handler(canvas));
  });

  card.addEventListener('mouseleave', () => {
    const cleanup = cleanups.get(card);
    if (cleanup) { cleanup(); cleanups.delete(card); }
  });
});

// ── SCROLL RISE ──
(function () {
  const SEL = '.eyebrow, h2, .section-sub, .screenshot-card, .event-card, .step, .platform-card, .cta-title, .cta-sub, .cta-actions';
  // Pre-mark all below-fold targets as paused-rise before they scroll into view
  document.querySelectorAll('.section').forEach(section => {
    section.querySelectorAll(SEL).forEach(el => el.classList.add('rise'));
  });

  const io = new IntersectionObserver((entries, obs) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      entry.target.querySelectorAll('.rise:not(.playing)').forEach((el, i) => {
        el.style.setProperty('--d', `${i * 0.07}s`);
        el.classList.add('playing');
      });
      obs.unobserve(entry.target);
    });
  }, { threshold: 0.08 });

  document.querySelectorAll('.section').forEach(s => io.observe(s));
}());
</script>
