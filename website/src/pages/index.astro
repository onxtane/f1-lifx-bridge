---
const version = "0.8.0";
const downloadUrl = `https://github.com/onxtane/f1-lifx-bridge/releases/download/v${version}/F1LifxBridge-v${version}.zip`;
const githubUrl = "https://github.com/onxtane/f1-lifx-bridge";

// Used for the hero light strip only
const events = [
  { color: "#ef4444", delay: "0s"   },
  { color: "#22c55e", delay: "0.3s" },
  { color: "#f59e0b", delay: "0.6s" },
  { color: "#60a5fa", delay: "0.9s" },
  { color: "#ef4444", delay: "1.2s" },
  { color: "#c084fc", delay: "1.5s" },
  { color: "#f8fafc", delay: "1.8s" },
  { color: "#cbd5e1", delay: "2.1s" },
  { color: "#fbbf24", delay: "2.4s" },
];

const gamePages = [
  {
    id: "f1",
    name: "F1 25–21",
    accentColor: "#8b7cf6",
    eyebrow: "9 RACE EVENTS",
    headline: "Every moment on track.",
    sub: "Nine distinct effects fire the instant F1 25 through F1 21 broadcasts the event — each mapped to a colour, a pulse, a sweep across your room.",
    events: [
      { name: "Start Lights",   color: "#ef4444", desc: "Zones sweep red, light by light",       delay: "0s",   id: "start-lights"   },
      { name: "Lights Out",     color: "#22c55e", desc: "Full green flash at race start",         delay: "0.1s", id: "lights-out"     },
      { name: "Yellow Flag",    color: "#f59e0b", desc: "Safety car — steady amber pulse",        delay: "0.2s", id: "yellow-flag"    },
      { name: "Blue Flag",      color: "#60a5fa", desc: "Lapped traffic warning",                 delay: "0.3s", id: "blue-flag"      },
      { name: "Red Flag",       color: "#ef4444", desc: "Session suspended",                      delay: "0.4s", id: "red-flag"       },
      { name: "Fastest Lap",    color: "#c084fc", desc: "Purple flash on personal best",          delay: "0.5s", id: "fastest-lap"    },
      { name: "Chequered Flag", color: "#f8fafc", desc: "Race end",                              delay: "0.6s", id: "chequered-flag" },
      { name: "White Warning",  color: "#cbd5e1", desc: "Slow vehicle on track",                  delay: "0.7s", id: "white-warning"  },
      { name: "Neutral",        color: "#fbbf24", desc: "Returns to your idle colour",            delay: "0.8s", id: "neutral"        },
    ],
  },
  {
    id: "dr2",
    name: "DiRT Rally 2.0",
    accentColor: "#22c55e",
    eyebrow: "5 STAGE EVENTS",
    headline: "From stage start to service park.",
    sub: "Five effects fire the moment DiRT Rally 2.0 broadcasts a packet — each split, each finish, each crash, each return to service park reflected in your room.",
    events: [
      { name: "Stage Start",      color: "#22c55e", desc: "Green flash when the stage begins",      delay: "0s",   id: "lights-out"     },
      { name: "Split Checkpoint", color: "#c084fc", desc: "Purple flash at each split checkpoint",  delay: "0.15s",id: "fastest-lap"    },
      { name: "Stage Finish",     color: "#f8fafc", desc: "Celebration flash at stage end",         delay: "0.3s", id: "chequered-flag" },
      { name: "Service Park",     color: "#fbbf24", desc: "Warm white on return to service park",   delay: "0.45s",id: "neutral"        },
      { name: "Crash",            color: "#f97316", desc: "Sharp white impact flash on collision",  delay: "0.6s", id: "crash"          },
    ],
  },
];

const features = [
  { title: "Sub-second latency",    desc: "Direct LAN. No cloud relay, no subscription, no middleman. The light fires when the event fires." },
  { title: "Profiles",              desc: "Save your entire setup — lights, effects, brightness, idle colour — and switch between them instantly." },
  { title: "Light Assignment",      desc: "Full per-effect control. Assign specific lights to specific events. Yellow flag in one room, start lights in another." },
  { title: "Multizone sweep",       desc: "Start lights fill zones left-to-right across your LIFX strip, one by one, matching the real on-screen sequence." },
  { title: "Panel Layout UI",       desc: "Drag your Nanoleaf panels to match your physical wall. The sweep follows your layout — not the API's arbitrary order." },
  { title: "UDP Forwarding",        desc: "Relay telemetry to a second destination simultaneously. Sim dashboard software, second PC — your call." },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GridGlow — Feel the race in your room</title>
  <meta name="description" content="Sync your LIFX and Nanoleaf lights to live F1 25–21 race events. Start lights, yellow flags, fastest laps — every moment on track, reflected in your room. No cloud. Sub-second latency." />
  <meta property="og:title" content="GridGlow" />
  <meta property="og:description" content="Feel the race in your room. Nine race events. Your LIFX and Nanoleaf lights. Sub-second, over LAN." />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

  <!-- ═══ NAV ═══ -->
  <nav>
    <div class="nav-inner">
      <span class="nav-logo">
        <span class="logo-dot"></span>
        GridGlow
      </span>
      <div class="nav-actions">
        <a href="/roadmap" class="btn-ghost">Roadmap</a>
        <a href={githubUrl} class="btn-ghost" target="_blank" rel="noopener">GitHub</a>
        <a href={downloadUrl} class="btn-primary nav-dl">Download <span class="ver">v{version}</span></a>
      </div>
    </div>
  </nav>

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero-glow glow-purple"></div>
    <div class="hero-glow glow-red"></div>
    <div class="hero-glow glow-teal"></div>

    <div class="hero-inner">
      <div class="hero-badge rise" style="--d:.05s">F1 25–21 &nbsp;·&nbsp; DiRT Rally 2.0 &nbsp;·&nbsp; LIFX &nbsp;·&nbsp; Nanoleaf &nbsp;·&nbsp; Hue</div>

      <h1 class="rise" style="--d:.14s">From lights out<br/><em>to chequered flag.</em></h1>

      <p class="hero-sub rise" style="--d:.24s">
        Every flag, every start light, every fastest lap — reflected instantly in your LIFX, Nanoleaf, and Philips Hue lights.
        No cloud. No delay. Pure LAN.
      </p>

      <div class="hero-actions rise" style="--d:.34s">
        <a href={downloadUrl} class="btn-primary btn-xl">
          Download v{version}
          <span class="btn-chip">Windows</span>
        </a>
        <a href={githubUrl} class="btn-ghost btn-xl" target="_blank" rel="noopener">
          View on GitHub →
        </a>
      </div>

      <p class="hero-meta rise" style="--d:.42s">Free · Open source · No account required</p>
      <p class="hero-meta rise" style="--d:.48s; opacity:.55;">macOS support in development</p>
    </div>

    <!-- light strip bar -->
    <div class="hero-strip">
      {events.map(e => (
        <div class="strip-segment" style={`--c: ${e.color}; --delay: ${e.delay}`}></div>
      ))}
    </div>
  </section>

  <!-- ═══ SCREENSHOTS ═══ -->
  <section class="section screenshots-section">
    <div class="container">
      <p class="eyebrow">THE APP</p>
      <h2>Built for race day.</h2>
      <p class="section-sub">Everything you need, nothing you don't. Set it up once, leave it running.</p>

      <div class="screenshots-grid">
        <div class="screenshot-card screenshot-main">
          <div class="screenshot-label">Dashboard</div>
          <img src="/screenshots/dashboard.png" alt="GridGlow dashboard showing bridge status, discovered lights, race control log and quick effect buttons" loading="lazy" />
        </div>
        <div class="screenshot-card">
          <div class="screenshot-label">Effects</div>
          <img src="/screenshots/effects.png" alt="Effects page showing per-event toggles for all race flags" loading="lazy" />
        </div>
        <div class="screenshot-card">
          <div class="screenshot-label">Light Assignment</div>
          <img src="/screenshots/assignment.png" alt="Light assignment page showing per-light effect chip selection" loading="lazy" />
        </div>
        <div class="screenshot-card">
          <div class="screenshot-label">Profiles</div>
          <img src="/screenshots/profiles.png" alt="Profiles page showing saved configurations" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ EVENTS CAROUSEL ═══ -->
  <section class="section events-section">
    <div class="container">

      <!-- nav row -->
      <div class="ev-nav">
        <button class="ev-arrow" id="evPrev" aria-label="Previous game">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <div class="ev-nav-center">
          <p class="eyebrow ev-eyebrow" id="evEyebrow">{gamePages[0].eyebrow}</p>
          <div class="ev-game-name" id="evGameName">{gamePages[0].name}</div>
          <div class="ev-dots" id="evDots">
            {gamePages.map((_, i) => (
              <button class={`ev-dot${i === 0 ? ' active' : ''}`} data-index={i} aria-label={`Go to ${gamePages[i].name}`}></button>
            ))}
          </div>
        </div>
        <button class="ev-arrow" id="evNext" aria-label="Next game">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>

      <!-- per-game headline + sub -->
      <div class="ev-header" id="evHeader">
        <h2 id="evHeadline">{gamePages[0].headline}</h2>
        <p class="section-sub" id="evSub">{gamePages[0].sub}</p>
      </div>

      <!-- pages -->
      <div class="ev-viewport" id="evViewport">
        {gamePages.map((game, gi) => (
          <div class={`ev-page${gi === 0 ? ' active' : ''}`} data-game={game.id}>
            <div class="events-grid">
              {game.events.map(e => (
                <div class="event-card" data-effect={e.id} style={`--c: ${e.color}; --delay: ${e.delay}`}>
                  <div class="effect-canvas"></div>
                  <div class="event-bar"></div>
                  <div class="event-name">{e.name}</div>
                  <div class="event-desc">{e.desc}</div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══ HOW IT WORKS ═══ -->
  <section class="section steps-section">
    <div class="container">
      <p class="eyebrow">SETUP</p>
      <h2>Three steps. That's it.</h2>

      <div class="steps">
        <div class="step">
          <div class="step-num">01</div>
          <div class="step-body">
            <h3>Discover your lights</h3>
            <p>Open the app, go to Lights, and hit Discover. Your LIFX and Nanoleaf devices appear automatically. Select the ones you want.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">02</div>
          <div class="step-body">
            <h3>Enable UDP telemetry in your F1 title</h3>
            <p>Settings → Telemetry Settings. Set UDP to On, point it at your PC's local IP, your chosen port (20777 by default).</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">03</div>
          <div class="step-body">
            <h3>Start the bridge</h3>
            <p>Hit Start Bridge. From that moment on, every race event fires your lights automatically — whether you're watching or racing.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PLATFORMS ═══ -->
  <section class="section platforms-section">
    <div class="container">
      <p class="eyebrow">SUPPORTED DEVICES</p>
      <h2>LIFX. Nanoleaf. Philips Hue.</h2>

      <div class="platforms-grid">
        <div class="platform-card lifx-card">
          <div class="platform-accent"></div>
          <div class="platform-icon">
            <!-- Tabler bulb -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 12h1m8-9v1m8 8h1m-15.4-6.4l.7.7m12.1-.7l-.7.7"/>
              <path d="M9 16a5 5 0 1 1 6 0a3.5 3.5 0 0 0-1 3a2 2 0 0 1-4 0a3.5 3.5 0 0 0-1-3"/>
              <path d="M9.7 17l4.6 0"/>
            </svg>
          </div>
          <h3>LIFX</h3>
          <p>Bulbs, strips, and multizone devices. The start lights sweep zone by zone across your strip — matching the real on-screen sequence, light by light.</p>
          <ul>
            <li>Bulbs &amp; colour strips</li>
            <li>Multizone — zone-by-zone sweep</li>
            <li>Stagger mode</li>
            <li>Master brightness range</li>
          </ul>
        </div>

        <div class="platform-card nanoleaf-card">
          <div class="platform-accent"></div>
          <div class="platform-icon">
            <!-- Tabler hexagons -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 18v-5l4-2l4 2v5l-4 2l-4-2"/>
              <path d="M8 11v-5l4-2l4 2v5"/>
              <path d="M12 13l4-2l4 2v5l-4 2l-4-2"/>
            </svg>
          </div>
          <h3>Nanoleaf</h3>
          <p>Canvas, Shapes, Lines, Elements, Light Panels. The Panel Layout UI maps the start lights sweep to your physical panel arrangement on the wall.</p>
          <ul>
            <li>Canvas, Shapes, Lines, Elements</li>
            <li>Panel Layout UI</li>
            <li>Position-based sweep</li>
            <li>Local REST API — no cloud</li>
          </ul>
        </div>

        <div class="platform-card hue-card">
          <div class="platform-accent"></div>
          <div class="platform-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 16a5 5 0 1 1 6 0a3.5 3.5 0 0 0-1 3a2 2 0 0 1-4 0a3.5 3.5 0 0 0-1-3"/>
              <path d="M9.7 17l4.6 0"/>
              <path d="M3 12h1m8-9v1m8 8h1m-15.4-6.4l.7.7m12.1-.7l-.7.7"/>
            </svg>
          </div>
          <h3>Philips Hue</h3>
          <p>Bulbs and Gradient Lightstrip Plus, all running over your home network — no internet required. The Gradient Lightstrip fills up segment by segment during the start lights sequence, matching the on-screen countdown light by light.</p>
          <ul>
            <li>Bulbs &amp; colour strips</li>
            <li>Gradient Lightstrip — segment sweep</li>
            <li>Hue Bridge on your network</li>
            <li>No cloud, no subscription</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FEATURES ═══ -->
  <section class="section features-section">
    <div class="container">
      <p class="eyebrow">FEATURES</p>
      <h2>Everything you need.<br/>Nothing you don't.</h2>

      <div class="features-grid">
        {features.map(f => (
          <div class="feature-card">
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ DOWNLOAD CTA ═══ -->
  <section class="section cta-section">
    <div class="cta-glow"></div>
    <div class="container cta-inner">
      <h2>Ready for another layer of immersion?</h2>
      <p>Free. Open source. Runs entirely on your local network.</p>
      <a href={downloadUrl} class="btn-primary btn-xl btn-cta">
        Download GridGlow
        <span class="btn-chip">v{version} · Windows</span>
      </a>
      <p class="cta-meta">Supports F1 25–21 &amp; DiRT Rally 2.0 · Requires UDP telemetry enabled &amp; LIFX, Nanoleaf, or Philips Hue on the same network</p>
    </div>
  </section>

  <script id="gameData" type="application/json" set:html={JSON.stringify(gamePages.map(g => ({ name: g.name, eyebrow: g.eyebrow, headline: g.headline, sub: g.sub })))}></script>

  <!-- ═══ FOOTER ═══ -->
  <footer>
    <div class="container footer-inner">
      <span class="footer-logo">GridGlow</span>
      <div class="footer-links">
        <a href={githubUrl} target="_blank" rel="noopener">GitHub</a>
        <a href={`${githubUrl}/releases`} target="_blank" rel="noopener">Releases</a>
        <a href={`${githubUrl}/issues`} target="_blank" rel="noopener">Issues</a>
        <a href={`${githubUrl}/blob/main/CHANGELOG.md`} target="_blank" rel="noopener">Changelog</a>
      </div>
      <p class="footer-disclaimer">Not affiliated with Formula 1, FIA, LIFX, or Nanoleaf.</p>
    </div>
  </footer>

</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:       #0b1020;
    --card:     rgba(255,255,255,0.05);
    --border:   rgba(255,255,255,0.10);
    --border-s: rgba(255,255,255,0.06);
    --purple:   #8b7cf6;
    --purple-l: #a78bfa;
    --text:     #f3f5f9;
    --muted:    #aab2c5;
    --faint:    rgba(170,178,197,0.45);
    --red:      #ef4444;
    --green:    #22c55e;
    --teal:     #06b6d4;
    --radius:   14px;
    --radius-s: 10px;
  }

  html { scroll-behavior: smooth; }

  /* ── PAGE-LOAD RISE ── */
  @keyframes rise {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .rise {
    opacity: 0;
    animation: rise .52s cubic-bezier(.22,.8,.36,1) both;
    animation-delay: var(--d, 0s);
    animation-play-state: paused;
  }
  /* hero children run immediately; below-fold get .playing added by IntersectionObserver */
  .hero .rise,
  .rise.playing { animation-play-state: running; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* ── UTILS ── */
  .container {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 28px;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 200;
    background: rgba(11,16,32,0.75);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border-s);
  }
  .nav-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 28px;
    height: 58px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 10px;
    letter-spacing: -0.2px;
  }
  .logo-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--purple);
    box-shadow: 0 0 8px var(--purple);
    flex-shrink: 0;
  }
  .nav-actions { display: flex; align-items: center; gap: 10px; }

  /* ── BUTTONS ── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--purple);
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    padding: 9px 20px;
    border-radius: var(--radius-s);
    text-decoration: none;
    transition: background 0.15s, transform 0.1s, box-shadow 0.15s;
    white-space: nowrap;
  }
  .btn-primary:hover {
    background: #7c6de8;
    transform: translateY(-1px);
    box-shadow: 0 6px 24px rgba(139,124,246,0.35);
  }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--muted);
    font-size: 14px;
    font-weight: 500;
    padding: 9px 18px;
    border-radius: var(--radius-s);
    border: 1px solid var(--border);
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
    white-space: nowrap;
  }
  .btn-ghost:hover {
    color: var(--text);
    border-color: rgba(255,255,255,0.22);
    background: rgba(255,255,255,0.04);
  }
  .btn-xl { font-size: 15px; padding: 13px 28px; border-radius: var(--radius); }
  .btn-chip {
    background: rgba(255,255,255,0.18);
    border-radius: 6px;
    padding: 2px 8px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.3px;
  }
  .ver { opacity: 0.75; font-weight: 400; }

  /* ── HERO ── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 80px 28px 0;
  }

  .hero-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }
  .glow-purple {
    width: 900px; height: 700px;
    background: radial-gradient(circle, rgba(139,124,246,0.22) 0%, transparent 65%);
    top: -200px; left: -200px;
    animation: breathe 6s ease-in-out infinite;
  }
  .glow-red {
    width: 500px; height: 400px;
    background: radial-gradient(circle, rgba(239,68,68,0.14) 0%, transparent 65%);
    bottom: 100px; right: 100px;
    animation: breathe 4s ease-in-out infinite 1.5s;
  }
  .glow-teal {
    width: 400px; height: 300px;
    background: radial-gradient(circle, rgba(6,182,212,0.10) 0%, transparent 65%);
    bottom: 50px; left: 200px;
    animation: breathe 5s ease-in-out infinite 3s;
  }
  @keyframes breathe {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50%       { opacity: 1;   transform: scale(1.06); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 760px;
    text-align: center;
    padding-bottom: 60px;
  }
  .hero-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    color: var(--purple-l);
    background: rgba(139,124,246,0.12);
    border: 1px solid rgba(139,124,246,0.28);
    border-radius: 99px;
    padding: 5px 16px;
    margin-bottom: 32px;
    text-transform: uppercase;
  }
  .hero-inner h1 {
    font-size: clamp(52px, 9vw, 88px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -2px;
    color: var(--text);
    margin-bottom: 24px;
  }
  .hero-inner h1 em {
    font-style: normal;
    color: var(--purple-l);
  }
  .hero-sub {
    font-size: 18px;
    color: var(--muted);
    line-height: 1.65;
    max-width: 560px;
